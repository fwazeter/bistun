# Bistun LMS: Environment Configuration Template
# Ref: [001-LMS-CORE]

# Deployment Mode: development | production
LMS_ENV=development

# The Ed25519 Public Key generated by 'cargo run -p bistun-api --bin curator'
# This is mandatory to unlock the security gate.
CURATOR_PUBLIC_KEY="PASTE_YOUR_PUBLIC_KEY_HERE"

# Optional: Remote registry URL (requires 'network' feature)
# LMS_REGISTRY_URL="https://cdn.bistun.io/v1/snapshot.json"